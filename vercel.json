{
  "version": 2,
  "builds": [
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "^/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "^/(?!api)(.*)$",
      "dest": "/$1.html",
      "status": 200
    },
    {
      "src": "^/$",
      "dest": "/index.html"
    }
  ]
}
